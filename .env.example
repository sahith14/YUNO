# =========================================================
# YUNO — environment template
# Copy to .env (root) for docker-compose and to each app's
# .env.local for individual dev runs.
# =========================================================

# ---------- Postgres ----------
POSTGRES_USER=yuno
POSTGRES_PASSWORD=yuno_dev_pw
POSTGRES_DB=yuno
POSTGRES_PORT=5432
DATABASE_URL=postgresql://yuno:yuno_dev_pw@localhost:5432/yuno?schema=public

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ---------- API server ----------
API_PORT=4000
API_HOST=0.0.0.0
API_PUBLIC_URL=http://localhost:4000

# JWT — rotate in prod, use 64+ random bytes
JWT_SECRET=dev-only-replace-me-with-64-bytes-of-random-data
JWT_GUEST_TTL=86400        # 24h
JWT_USER_TTL=2592000       # 30d

# ---------- Signaling server ----------
SIGNALING_PORT=4001
SIGNALING_HOST=0.0.0.0
SIGNALING_PUBLIC_URL=ws://localhost:4001

# Cross-server shared secret for service-to-service calls
INTERNAL_SECRET=change-me-internal-secret

# ---------- Web ----------
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SIGNALING_URL=ws://localhost:4001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- TURN / Coturn ----------
# Used by the API to mint short-lived TURN credentials (HMAC-SHA1, RFC 7635 / time-based).
TURN_HOST=turn.yuno.local
TURN_PORT=3478
TURN_TLS_PORT=5349
TURN_REALM=yuno.local
TURN_SHARED_SECRET=change-me-turn-shared-secret
TURN_CRED_TTL=3600         # 1h

# Public ICE servers (comma separated). STUN free; TURN as fallback.
NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# ---------- Stripe (premium) ----------
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_PREMIUM_MONTHLY=price_replace_me
STRIPE_PRICE_VERIFIED_FEMALE=price_replace_me

# ---------- Verification provider (Stripe Identity / Veriff) ----------
VERIFICATION_PROVIDER=stripe-identity
VERIFICATION_WEBHOOK_SECRET=whsec_replace_me

# ---------- Moderation ----------
MODERATION_ENABLED=true
MODERATION_FRAME_INTERVAL_MS=15000   # client samples a thumbnail every 15s
MODERATION_REPORT_THRESHOLD=3        # auto-shadow-ban after N valid reports

# ---------- Rate limits ----------
RATE_LIMIT_PAIRINGS_PER_MIN=30
RATE_LIMIT_REPORTS_PER_HOUR=10

# ---------- Observability ----------
LOG_LEVEL=info
SENTRY_DSN=
